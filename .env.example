DATABASE_URL="file:./prisma/dev.db"

# Required in production. Users must authenticate with this value before
# accessing resume, application, AI, or browser automation APIs.
OFFER_CATCHER_ACCESS_TOKEN="replace-with-a-long-random-token"

# Optional LLM provider configuration.
MIMO_API_KEY=""
MIMO_BASE_URL="https://token-plan-sgp.xiaomimimo.com/v1"
MIMO_MODEL="mimo-v2.5-pro"

# Dangerous browser automation is disabled unless explicitly enabled.
BOSS_AUTOMATION_ENABLED="false"
BOSS_HEADLESS="true"
