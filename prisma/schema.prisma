generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  name          String?
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  resumes       Resume[]
  applications  Application[]
  preferences   UserPreference[]
  agentSessions AgentSession[]
}

model Resume {
  id        String   @id @default(cuid())
  name      String
  email     String   @default("")
  phone     String   @default("")
  rawText   String
  source    String   @default("rule")
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  deviceId  String?

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  educations   Education[]
  experiences  Experience[]
  projects     Project[]
  skills       ResumeSkill[]
  applications Application[]

  @@index([deviceId])
}

model Education {
  id        String  @id @default(cuid())
  resumeId  String
  school    String
  major     String  @default("")
  degree    String  @default("")
  year      String  @default("")
  startYear String?
  endYear   String?
  gpa       String?

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String  @id @default(cuid())
  resumeId    String
  company     String
  title       String
  startDate   String?
  endDate     String?
  duration    String  @default("")
  description String  @default("")

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Project {
  id          String  @id @default(cuid())
  resumeId    String
  name        String
  description String  @default("")
  techStack   String  @default("[]")
  url         String?

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model ResumeSkill {
  id       String @id @default(cuid())
  resumeId String
  name     String

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}

model Job {
  id           String   @id @default(cuid())
  sourceId     String?  @unique
  source       String   @default("manual")
  title        String
  company      String
  location     String
  salaryMin    Int?
  salaryMax    Int?
  salaryText   String?
  experience   String
  education    String
  description  String
  requirements String   @default("[]")
  skills       String   @default("[]")
  tags         String   @default("[]")
  postedAt     DateTime?
  applyUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  applications Application[]

  @@unique([title, company])
}

model Application {
  id           String   @id @default(cuid())
  userId       String?
  deviceId     String?
  resumeId     String?
  jobId        String?
  jobSnapshot  String?  @default("{}")
  matchScore   Float?
  matchDetail  String?  @default("{}")
  status       String   @default("applied")
  method       String   @default("manual")
  notes        String?
  appliedAt    DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  resume Resume? @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  job    Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)
  history ApplicationStatusHistory[]

  @@index([status])
  @@index([appliedAt])
  @@index([resumeId])
  @@index([jobId])
  @@index([deviceId])
}

model ApplicationStatusHistory {
  id            String   @id @default(cuid())
  applicationId String
  fromStatus    String
  toStatus      String
  note          String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
}

// ========== Agent Memory Models ==========

model AgentSession {
  id        String   @id @default(cuid())
  userId    String?
  deviceId  String?
  sessionId String   @unique
  data      String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([deviceId])
}

model AgentMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  metadata  String?
  createdAt DateTime @default(now())

  // Relate via AgentSession.sessionId (the application-level UUID that all
  // read/write paths use) rather than the cuid primary key, so messages are
  // never orphaned from their session.
  session AgentSession @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model UserPreference {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

// ========== Interview / 面试刷题模型 ==========

model InterviewQuestion {
  id         String   @id
  module     String
  difficulty Int      // 1=初级, 2=中级, 3=高级
  question   String
  answer     String
  tags       String   @default("[]")  // JSON array of strings
  source     String?  // "builtin" | "custom_<importId>"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  studyRecords InterviewStudyRecord[]
  notes        InterviewNote[]
  flags        InterviewFlag[]

  @@index([module])
  @@index([difficulty])
  @@index([source])
}

model InterviewStudyRecord {
  id          String   @id @default(cuid())
  deviceId    String   @default("legacy")
  questionId  String
  status      String   @default("unlearned")  // unlearned|mastered|review
  lastUpdated DateTime @default(now())
  reviewCount Int      @default(0)

  question InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([deviceId, questionId])
  @@index([deviceId])
}

model InterviewNote {
  id         String   @id @default(cuid())
  deviceId   String   @default("legacy")
  questionId String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([deviceId, questionId])
  @@index([deviceId])
}

model InterviewFlag {
  id         String   @id @default(cuid())
  deviceId   String   @default("legacy")
  questionId String
  starred    Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question InterviewQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([deviceId, questionId])
  @@index([deviceId])
}

model MockInterview {
  id         String   @id @default(cuid())
  deviceId   String?
  status     String   @default("planning")  // planning|interviewing|completed
  plan       String?  // JSON: {summary, focusAreas, sections, openingQuestion}
  turns      String   @default("[]")  // JSON array of {role, content, timestamp}
  report     String?  // Markdown 复盘报告
  score      Float?
  jobTitle   String?
  jobLevel   String?
  jdText     String?
  resumeText String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([deviceId])
}
